#!/usr/bin/env sh

# Check if any UI/TypeScript files were modified
UI_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '\.(js|ts|jsx|tsx|css|json)$' | grep -E '^(ui/|\.eslintrc|tsconfig|package\.json)' || true)

if [ -n "$UI_FILES" ]; then
  echo "UI files changed, running UI checks..."
  echo "Modified UI files: $UI_FILES"
  
  cd ui

  # Run tests when any UI files change (not just test files)
  # This catches regressions when components are modified
  echo "🧪 Running tests to check for regressions..."
  npm test

  # Run theme compliance check to ensure no hardcoded colors
  echo "🎨 Running theme compliance check..."
  npm test -- theme-compliance.test.ts

  # Run lint and type-check
  echo "🔍 Running lint and type-check..."
  npm run lint && npm run type-check
  
  cd ..
else
  echo "📋 No UI files changed, skipping UI checks"
fi

# Check if any proxy files were modified
PROXY_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '^(functions/proxy/)' || true)

if [ -n "$PROXY_FILES" ]; then
  echo "Proxy files changed, running proxy tests..."
  echo "Modified proxy files: $PROXY_FILES"
  
  cd functions/proxy

  # Run proxy tests when any proxy files change
  echo "🧪 Running proxy tests..."
  npm test
  
  cd ../..
else
  echo "📋 No proxy files changed, skipping proxy tests"
fi

# Go back to root and check versions only if relevant files changed
cd ..

# Check if any relevant files were modified
RELEVANT_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '(indexing-job/|aoe-search/|scripts/check-versions\.sh)' || true)

if [ -n "$RELEVANT_FILES" ]; then
    echo "📋 Relevant files changed, checking version consistency..."
    echo "Modified files: $RELEVANT_FILES"
    
    if [ -f "scripts/check-versions.sh" ]; then
        ./scripts/check-versions.sh
        echo "✅ Version check passed"
    else
        echo "⚠️ Version check script not found, skipping"
    fi
else
    echo "📋 No relevant files changed, skipping version check"
fi
