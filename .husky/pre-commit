#!/usr/bin/env sh

cd ui

# Get staged files that are test files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(test|spec)\.(js|ts|jsx|tsx)$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "Running tests on changed files: $STAGED_FILES"
  # Run tests only on changed test files
  npm test -- --findRelatedTests $STAGED_FILES
else
  echo "No test files changed, skipping tests"
fi

# Always run lint and type-check
npm run lint && npm run type-check

# Go back to root and check versions only if relevant files changed
cd ..

# Check if any relevant files were modified
RELEVANT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(indexing-job/|aoe-search/|scripts/check-versions\.sh)' || true)

if [ -n "$RELEVANT_FILES" ]; then
    echo "📋 Relevant files changed, checking version consistency..."
    echo "Modified files: $RELEVANT_FILES"
    
    if [ -f "scripts/check-versions.sh" ]; then
        ./scripts/check-versions.sh
        echo "✅ Version check passed"
    else
        echo "⚠️ Version check script not found, skipping"
    fi
else
    echo "📋 No relevant files changed, skipping version check"
fi
