{
  "name": "aoe2-api-proxy",
  "version": "1.0.0",
  "description": "Proxy for AoE2 API with caching",
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "functions-framework --target=proxy",
    "dev": "functions-framework --target=proxy --port=8080",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.1.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "16.5.0",
    "node-fetch": "^2.6.7",
    "pino": "9.7.0",
    "steam-user": "^4.28.0"
  },
  "devDependencies": {
    "@google-cloud/functions-framework": "^3.3.0",
    "jest": "^29.7.0",
    "pino-pretty": "13.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "*.js",
      "!*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
