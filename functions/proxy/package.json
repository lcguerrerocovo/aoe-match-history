{
  "name": "aoe2-api-proxy",
  "version": "1.0.0",
  "description": "Proxy for AoE2 API with caching",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "functions-framework --target=proxy --source=dist",
    "dev": "lsof -ti :8080 | xargs kill -9 2>/dev/null; tsc && functions-framework --target=proxy --source=dist --port=8080",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.1.0",
    "@google-cloud/functions-framework": "^3.3.0",
    "cors": "^2.8.5",
    "dotenv": "16.5.0",
    "pg": "8.20.0",
    "pino": "9.7.0",
    "steam-user": "^4.28.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/node": "25.5.0",
    "@types/pg": "8.20.0",
    "jest": "^29.7.0",
    "pino-pretty": "13.0.0",
    "supertest": "7.1.1",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3"
  },
  "jest": {
    "preset": "ts-jest/presets/js-with-ts",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "*.ts",
      "!*.d.ts",
      "!*.test.js",
      "!relicPlayerService.ts",
      "!replayDownloadHandler.ts",
      "!replayService.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
